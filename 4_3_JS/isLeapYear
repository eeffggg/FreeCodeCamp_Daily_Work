let year;
let result;

const isLeapYear = year =>{
  if((year % 4)){
    return `${year} is not a leap year.`;
  }else if(!(year % 100)){
    return !(year % 400) ? `${year} is a leap year.` : `${year} is not a leap year.`;
  }else{
    return `${year} is a leap year.`;
  }
}


year = 1604;
result = isLeapYear(year);
console.log(result);
